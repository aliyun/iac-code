msgid "conclusion must match this schema summary:\n"
msgstr "conclusion は次のスキーマ概要に一致する必要があります:\n"

#: src/iac_code/pipeline/engine/complete_step_tool.py
msgid "<fill according to the current step requirements>"
msgstr "<現在のステップ要件に従って入力>"

#: src/iac_code/pipeline/engine/complete_step_tool.py
msgid "Clarification is required before completing the current step."
msgstr "現在のステップを完了する前に確認が必要です。"

#: src/iac_code/pipeline/engine/complete_step_tool.py
#, python-brace-format
msgid ""
"{message} Call {required_tool} first, then call complete_step after "
"receiving the tool result."
msgstr "{message} まず {required_tool} を呼び出し、ツール結果を受け取ってから complete_step を呼び出してください。"

#: src/iac_code/pipeline/engine/complete_step_tool.py
msgid "Clarification output is required before completing the current step."
msgstr "現在のステップを完了する前に確認結果が必要です。"

#: src/iac_code/pipeline/engine/complete_step_tool.py
#, python-brace-format
msgid "{message} complete_step.conclusion must include {required_field}."
msgstr "{message} complete_step.conclusion には {required_field} が必要です。"

#: src/iac_code/pipeline/engine/complete_step_tool.py
msgid " or "
msgstr " または "

#: src/iac_code/pipeline/engine/complete_step_tool.py
#, python-brace-format
