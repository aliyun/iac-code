#: src/iac_code/agent/agent_types.py
msgid ""
"Use for complex, multi-step tasks that require research, code changes, or"
" coordinating multiple operations."
msgstr ""
"À utiliser pour les tâches complexes en plusieurs étapes qui nécessitent "
"de la recherche, des changements de code ou la coordination de plusieurs "
"opérations."

