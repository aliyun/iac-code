#: src/iac_code/pipeline/engine/complete_step_tool.py
msgid ""
"Complete the current step by calling this tool to submit the conclusion. "
"If you need to roll back to an earlier step, set rollback_request."
msgstr ""
"Conclua a etapa atual chamando esta ferramenta para enviar a conclusão. "
"Se precisar voltar a uma etapa anterior, defina rollback_request."

#: src/iac_code/pipeline/engine/complete_step_tool.py
msgid "Set this field when you need to roll back to an earlier step"
msgstr "Defina este campo quando precisar voltar a uma etapa anterior"

#: src/iac_code/pipeline/engine/complete_step_tool.py
msgid "Target step ID to roll back to"
msgstr "ID da etapa de destino para reverter"

#: src/iac_code/pipeline/engine/complete_step_tool.py
msgid "Reason for rollback"
msgstr "Motivo da reversão"

#: src/iac_code/pipeline/engine/complete_step_tool.py
msgid "Structured conclusion for the current step. Required and non-empty."
msgstr "Conclusão estruturada da etapa atual. Obrigatória e não vazia."

#: src/iac_code/pipeline/engine/complete_step_tool.py
#, python-brace-format
msgid ""
"{error}\n"
"Current step: {step_id}\n"
"Do not repeat the previous invalid arguments: {invalid_json}\n"
"complete_step arguments must be {{\"conclusion\": {{...}}}}; do not "
"submit empty arguments or put conclusion fields at the top level.\n"
"{schema_hint}\n"
"Outer argument example: {example}"
msgstr ""
"{error}\n"
"Etapa atual: {step_id}\n"
"Não repita os argumentos inválidos anteriores: {invalid_json}\n"
"Os argumentos de complete_step devem ser {{\"conclusion\": {{...}}}}; não"
" envie argumentos vazios nem coloque campos de conclusion no nível "
"superior.\n"
"{schema_hint}\n"
"Exemplo de argumentos externos: {example}"

#: src/iac_code/pipeline/engine/complete_step_tool.py
msgid ""
"conclusion must be a non-empty object; fill the structured conclusion "
"required by this step."
msgstr ""
"conclusion deve ser um objeto não vazio; preencha a conclusão estruturada"
" exigida por esta etapa."

#: src/iac_code/pipeline/engine/complete_step_tool.py
msgid "conclusion must match this schema summary:\n"
msgstr "conclusion deve corresponder a este resumo de esquema:\n"

#: src/iac_code/pipeline/engine/complete_step_tool.py
msgid "<fill according to the current step requirements>"
msgstr "<preencher conforme os requisitos da etapa atual>"

#: src/iac_code/pipeline/engine/complete_step_tool.py
msgid "Clarification is required before completing the current step."
msgstr "É necessário esclarecimento antes de concluir a etapa atual."

#: src/iac_code/pipeline/engine/complete_step_tool.py
#, python-brace-format
msgid ""
"{message} Call {required_tool} first, then call complete_step after "
"receiving the tool result."
msgstr ""
"{message} Chame {required_tool} primeiro e depois chame complete_step "
"após receber o resultado da ferramenta."

#: src/iac_code/pipeline/engine/complete_step_tool.py
msgid "Clarification output is required before completing the current step."
msgstr "A saída do esclarecimento é necessária antes de concluir a etapa atual."

#: src/iac_code/pipeline/engine/complete_step_tool.py
#, python-brace-format
msgid "{message} complete_step.conclusion must include {required_field}."
msgstr "{message} complete_step.conclusion deve incluir {required_field}."

#: src/iac_code/pipeline/engine/complete_step_tool.py
msgid " or "
msgstr " ou "

#: src/iac_code/pipeline/engine/complete_step_tool.py
#, python-brace-format
msgid ""
"{message} complete_step.conclusion must include one of these fields: "
"{fields}."
msgstr ""
"{message} complete_step.conclusion deve incluir um destes campos: "
"{fields}."

#: src/iac_code/pipeline/engine/complete_step_tool.py
msgid "A successful tool result is required before completing the current step."
msgstr ""
"É necessário um resultado de ferramenta bem-sucedido antes de concluir a "
"etapa atual."

