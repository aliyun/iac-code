msgid ""
"A2A transport: http, stdio, unix, websocket, grpc, grpc-jsonrpc, or "
"redis-streams"
msgstr "A2A トランスポート: http、stdio、unix、websocket、grpc、grpc-jsonrpc、または redis-streams"

